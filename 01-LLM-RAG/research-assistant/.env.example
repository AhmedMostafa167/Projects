# --- LLM provider selection ---
# Options: huggingface (default, free), groq, anthropic, openai
LLM_PROVIDER=huggingface

# --- API keys (set the one matching LLM_PROVIDER) ---
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxx
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Model configuration ---
# Used when LLM_PROVIDER=huggingface
HF_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct
# Used when LLM_PROVIDER=groq
GROQ_MODEL=llama-3.1-70b-versatile
# Used when LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Used when LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/chroma
COLLECTION_NAME=research_papers

# --- Retrieval ---
TOP_K_DENSE=10
TOP_K_BM25=10
TOP_K_RERANK=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- Generation ---
MAX_TOKENS=1024
TEMPERATURE=0.2

# --- Observability (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-assistant
LOG_LEVEL=INFO

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
