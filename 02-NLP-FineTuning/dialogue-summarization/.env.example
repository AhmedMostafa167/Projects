# --- Hugging Face ---
# Required for loading Llama-3.2 (gated) and pushing fine-tuned adapter
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxx

# --- Base model ---
BASE_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct

# --- LoRA hyperparameters ---
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

# --- Training ---
LEARNING_RATE=2e-4
NUM_EPOCHS=2
PER_DEVICE_BATCH_SIZE=2
GRADIENT_ACCUMULATION_STEPS=4
MAX_SEQ_LENGTH=1024
USE_4BIT=true

# --- Inference ---
MAX_NEW_TOKENS=128
TEMPERATURE=0.3
TOP_P=0.9

# --- Adapter repo on the HF Hub (filled in after training/pushing) ---
HF_ADAPTER_REPO=
